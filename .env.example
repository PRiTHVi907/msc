# Confidential Environment Variables
# COPY THIS FILE TO `.env` AND FILL IN YOUR SECRETS
# DO NOT COMMIT THE ACTUAL `.env` FILE TO VERSION CONTROL

# Postgres Database (e.g., Supabase, Heroku, or Local)
# Must use the asyncpg driver: postgresql+asyncpg://...
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/interview_db

# Twilio Credentials
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_API_KEY=your_twilio_api_key
TWILIO_API_SECRET=your_twilio_api_secret

# Security
JWT_SECRET_KEY=your_super_secret_jwt_signature_key

# Google Gemini API
GEMINI_API_KEY=your_google_gemini_api_key_here

# AWS S3 (For Video Uploads)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
S3_BUCKET_NAME=your-interview-recordings-bucket
AWS_ROLE_ARN=arn:aws:iam::123456789012:role/S3UploadPresignedRole
